{
  "name": "cipi/agent",
  "description": "Cipi Agent for Laravel — webhook deploy, health check, and server integration",
  "keywords": [
    "cipi",
    "laravel",
    "deploy",
    "cli",
    "php",
    "lemp",
    "server",
    "linux"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Andrea Pollastri",
      "homepage": "https://web.ap.it"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/console": "^12.0",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "Cipi\\Agent\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Cipi\\Agent\\Providers\\CipiAgentServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
